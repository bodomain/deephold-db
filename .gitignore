notebooks/*.html

# --- Bun / OpenTUI-TUI ----------------------------------------------------
# node_modules + Build-Caches; bun.lock wird eingecheckt (Reproduzierbarkeit)
tui/node_modules/
tui/dist/
tui/coverage/
# Falls jemand ein anderes Lockfile-Format erzeugt:
tui/bun.lockb

# --- Secrets & lokale Overrides ------------------------------------------
.env
.env.local
.env.*.local

# --- Daten / Caches (lokal) ----------------------------------------------
data/
downloads/
.parquet/
*.parquet
*.csv.gz

# --- Prefect --------------------------------------------------------------
.prefect/

# --- Docker ---------------------------------------------------------------
# Volumes werden in docker-compose volumes: {} definiert, kein Bind-Mount.

