# --- Python ---------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.ENV
ENV/

# --- Poetry ---------------------------------------------------------------
