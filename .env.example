# --- Postgres (docker-compose) -------------------------------------------
POSTGRES_USER=deephold
POSTGRES_PASSWORD=deephold
POSTGRES_DB=deephold
POSTGRES_PORT=5432

# --- SQLAlchemy / Alembic --------------------------------------------------
DATABASE_URL=postgresql+psycopg://deephold:deephold@localhost:5432/deephold

# --- Vendor API-Keys -------------------------------------------------------
FRED_API_KEY=
ECB_SDMX_BASE=https://data-api.ecb.europa.eu/service
BUNDESBANK_SDMX_BASE=https://api.statistiken.bundesbank.de/rest
YAHOO_ENABLED=true
STOOQ_ENABLED=true

# --- Prefect ---------------------------------------------------------------
PREFECT_API_URL=http://localhost:4200/api
PREFECT_HOME=/opt/prefect
PREFECT_PORT=4200

# --- Adminer ---------------------------------------------------------------
ADMINER_PORT=8080

# --- App -------------------------------------------------------------------
LOG_LEVEL=INFO
ENV=dev
